{
  "name": "@mindforge-x/musio",
  "version": "0.1.0",
  "description": "Launcher for the Musio local music agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindforge-x/musio.git",
    "directory": "packaging/npm"
  },
  "bin": {
    "musio": "bin/musio.js"
  },
  "files": [
