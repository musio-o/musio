    "prepublishOnly": "node scripts/verify-main-package.js"
  },
  "optionalDependencies": {
    "@mindforge-x/musio-linux-x64": "0.1.0",
    "@mindforge-x/musio-linux-arm64": "0.1.0",
    "@mindforge-x/musio-darwin-x64": "0.1.0",
    "@mindforge-x/musio-darwin-arm64": "0.1.0",
    "@mindforge-x/musio-win32-x64": "0.1.0",
    "@mindforge-x/musio-win32-arm64": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
